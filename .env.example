# API del backend (registro de tenants)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# URL del panel al que redirigir después del registro
NEXT_PUBLIC_PANEL_URL=http://localhost:3000

# Supabase (para futuras integraciones de leads/contactos)
# NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Meta Pixel (Facebook Ads)
# NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXX

# WhatsApp Business (número de contacto)
# NEXT_PUBLIC_WHATSAPP_NUMBER=598XXXXXXXX
